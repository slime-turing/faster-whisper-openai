IMAGE_NAME=ghcr.io/slime-turing/faster-whisper-openai
IMAGE_TAG=latest
CONTAINER_NAME=faster-whisper
STT_UID=1000
STT_GID=1000
STT_HOST_PORT=9001
STT_MODEL=large-v3-turbo
STT_DEVICE=cuda
STT_COMPUTE_TYPE=float16
STT_SKIP_MODEL_LOAD=false
STT_CPU_THREADS=4
STT_NUM_WORKERS=2
STT_BEAM_SIZE=5
STT_BEST_OF=5
STT_VAD_FILTER=true
STT_BATCH_SIZE=8
STT_MAX_CONCURRENT_JOBS=2
STT_LONG_FORM_SECONDS=240
STT_WEBSOCKET_MAX_SECONDS=900
STT_TMP_TTL_HOURS=6
STT_CACHE_MAX_GB=30
STT_CLEANUP_INTERVAL_SECONDS=3600
STT_ALLOW_ORIGINS=*
http_proxy=
https_proxy=
no_proxy=localhost,127.0.0.1,::1
HTTP_PROXY=
HTTPS_PROXY=
NO_PROXY=localhost,127.0.0.1,::1
